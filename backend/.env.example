APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Public URL (reverse proxy / HTTPS) ─────────────────────────────────────────
# Set to the public base URL behind a proxy so MCP OAuth redirect URIs are correct
# https URLs (providers reject http/internal ones during registration).
# PUBLIC_BASE_URL=https://agentflow.example.com
PUBLIC_BASE_URL=

# ── Auth ───────────────────────────────────────────────────────────────────────
# The management UI/API requires an admin login (created on first visit at /setup).
# SECRET_KEY signs session cookies; if blank a random key is generated and saved
# to data/.secret_key. SESSION_TTL_HOURS sets login lifetime. COOKIE_SECURE=true
# marks the cookie Secure (enable when serving over HTTPS).
SECRET_KEY=
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
